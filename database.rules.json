{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",

    "projects": {
      ".indexOn": ["createdBy", "status", "moderationStatus", "featured"]
    },

    "projectSubmissions": {
      ".indexOn": ["projectId", "authorId", "status"]
    },

    "projectShowcases": {
      ".indexOn": ["authorId", "status", "featured"]
    },

    "projectVotes": {
      "$projectId": {
        ".indexOn": ["userId", "submissionId"]
      }
    }
  }
}
